# Project ByteSaver — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Gemini API Key (https://aistudio.google.com/app/apikey)
# In production, load this server-side. For local dev/hackathon,
# the app accepts the key via the Settings modal (stored in sessionStorage only).
GEMINI_API_KEY=your_gemini_api_key_here
